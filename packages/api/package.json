{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "PORT=3001 bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "node ../../node_modules/.bin/vitest run",
    "test:watch": "node ../../node_modules/.bin/vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.73.0"
  }
}
